#!/usr/bin/env bash

set -euo pipefail

IMAGE_NAME="${IMAGE_NAME:-romrobotics/sensor_fusion:u20}"
CONTAINER_NAME="${CONTAINER_NAME:-sensor_fusion_x11_$$}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORKSPACE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
XSOCK="/tmp/.X11-unix"
XAUTH="/tmp/.docker.xauth"
DOCKER_ARGS=()

if [[ -z "${DISPLAY:-}" ]]; then
	echo "DISPLAY is not set. Run this from an X11 session." >&2
	exit 1
fi

if [[ ! -d "$XSOCK" ]]; then
	echo "X11 socket directory not found at $XSOCK." >&2
	exit 1
fi

if ! command -v docker >/dev/null 2>&1; then
	echo "docker is required but not installed." >&2
	exit 1
fi

if ! command -v xauth >/dev/null 2>&1; then
	echo "xauth is required for X11 forwarding." >&2
	exit 1
fi

if docker info --format '{{json .Runtimes}}' | grep -q '"nvidia"'; then
	DOCKER_ARGS+=(--runtime=nvidia --gpus all)
fi

if [[ -e /dev/dri/renderD128 ]]; then
	DOCKER_ARGS+=(--device /dev/dri/renderD128)
fi

if [[ -e /dev/dri/card1 ]]; then
	DOCKER_ARGS+=(--device /dev/dri/card1)
fi

touch "$XAUTH"
if xauth nlist "$DISPLAY" >/dev/null 2>&1; then
	xauth nlist "$DISPLAY" | sed -e 's/^..../ffff/' | xauth -f "$XAUTH" nmerge - >/dev/null 2>&1 || true
fi
chmod 644 "$XAUTH"

cleanup() {
	if command -v xhost >/dev/null 2>&1; then
		xhost -si:localuser:root >/dev/null 2>&1 || true
	fi
}

trap cleanup EXIT

if command -v xhost >/dev/null 2>&1; then
	xhost +si:localuser:root >/dev/null
fi

if docker ps -a --format '{{.Names}}' | grep -Fxq "$CONTAINER_NAME"; then
	docker rm -f "$CONTAINER_NAME" >/dev/null
fi

docker run --rm -it \
	--name "$CONTAINER_NAME" \
	--net=host \
	--ipc=host \
	"${DOCKER_ARGS[@]}" \
	-e DISPLAY="$DISPLAY" \
	-e XAUTHORITY="$XAUTH" \
	-e QT_X11_NO_MITSHM=1 \
	-e NVIDIA_VISIBLE_DEVICES=all \
	-e NVIDIA_DRIVER_CAPABILITIES=all \
	-v "$XSOCK:$XSOCK:rw" \
	-v "$XAUTH:$XAUTH:rw" \
	-v "$WORKSPACE_DIR:/workspace:rw" \
	-w /workspace \
	"$IMAGE_NAME" \
	"$@"
